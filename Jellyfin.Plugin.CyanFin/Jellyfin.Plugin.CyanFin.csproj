<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>Jellyfin.Plugin.CyanFin</AssemblyName>
    <RootNamespace>Jellyfin.Plugin.CyanFin</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <Version>1.0.0</Version>
    <Authors>Shamuoo</Authors>
    <Description>CyanFin Plugin for Jellyfin — trickplay, watch parties, push notifications and custom metadata.</Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- Jellyfin core — referenced but not bundled -->
    <PackageReference Include="Jellyfin.Controller" Version="10.9.*" />
    <PackageReference Include="Jellyfin.Model" Version="10.9.*" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Core" Version="2.2.5" />
  </ItemGroup>

  <!-- Don't copy Jellyfin's own DLLs into output -->
  <PropertyGroup>
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
  </PropertyGroup>

</Project>
